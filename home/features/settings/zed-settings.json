// Zed settings
//
// For information on how to configure Zed, see the Zed
// documentation: https://zed.dev/docs/configuring-zed
//
// To see all of Zed's default settings without changing your
// custom settings, run zed: open default settings from the
// command palette (cmd-shift-p / ctrl-shift-p)
{
  "lsp": {
    "vtsls": {
      "settings": {
        "typescript": {
          "updateImportsOnFileMove": {
            "enabled": "always"
          }
        },
        "javascript": {
          "updateImportsOnFileMove": {
            "enabled": "always"
          }
        }
      },
      "enable_lsp_tasks": true
    }
  },
  "languages": {
    "PHP": {
      "show_edit_predictions": true
    }
  },
  "git": {
    "inline_blame": {
      "show_commit_summary": true
    }
  },
  "tabs": {
    "git_status": false,
    "file_icons": false,
    "show_close_button": "hover"
  },
  "hard_tabs": false,
  "edit_predictions": {
    "provider": "copilot"
  },
  "agent": {
    "inline_assistant_model": {
      "provider": "copilot_chat",
      "model": "claude-sonnet-4.5",
      "enable_thinking": false
    },
    "default_model": {
      "provider": "copilot_chat",
      "model": "claude-sonnet-4.5"
    },
    "model_parameters": []
  },
  "agent_servers": {
    "kimi": {
      "type": "registry"
    },
    "codex-acp": {
      "type": "registry"
    },
    "claude-acp": {
      "type": "registry"
    },
    "github-copilot-cli": {
      "type": "registry"
    },
    "junie-acp": {
      "type": "registry"
    },
    "github-copilot": {
      "type": "registry"
    },
    "opencode": {
      "type": "extension",
      "favorite_models": ["opencode/kimi-k2.5-free"]
    }
  },
  "git_panel": {
    "sort_by_path": false,
    "status_style": "icon",
    "default_width": 290.0
  },
  "use_system_window_tabs": false,
  "preview_tabs": {
    "enable_preview_from_multibuffer": true,
    "enable_preview_from_project_panel": true,
    "enabled": false
  },
  "debugger": {
    "button": false
  },
  "diagnostics": {
    "button": true
  },
  "status_bar": {
    "cursor_position_button": false,
    "active_language_button": false
  },
  "search": {
    "button": false,
    "center_on_match": true
  },
  "sticky_scroll": {
    "enabled": false
  },
  "scroll_beyond_last_line": "vertical_scroll_margin",
  "autosave": "on_focus_change",
  "buffer_line_height": {
    "custom": 1.4
  },
  "restore_on_startup": "empty_tab",
  "terminal": {
    "dock": "bottom",
    "shell": "system"
  },
  "calls": {
    "mute_on_join": true
  },
  "icon_theme": "VSCode Icons for Zed (Dark NestJS)",
  "base_keymap": "JetBrains",
  "ui_font_size": 16,
  "buffer_font_size": 15,
  "theme": "Aura Dark",
  "theme_overrides": {
    "Aura Dark": {
      "border.variant": "#15141C",
      "border": "#15141C",
      "title_bar.background": "#15141C",
      "title_bar.foreground": "#BD9DFF",
      "panel.background": "#15141C",
      "panel.focused_border": "#4E466E",
      "players": [
        {
          "cursor": "#BD9DFF"
        }
      ],
      "syntax": {
        "comment": {
          "font_style": "italic"
        },
        "comment.doc": {
          "font_style": "italic"
        }
      }
    }
  },
  "title_bar": {
    "show_menus": false,
    "show_user_picture": true,
    "show_sign_in": true,
    "show_branch_name": true,
    "show_onboarding_banner": false,
    "show_project_items": false
  },
  "tab_bar": {
    "show_nav_history_buttons": false,
    "show_tab_bar_buttons": false,
    "show": true
  },
  "toolbar": {
    "quick_actions": false
  },
  "project_panel": {
    "auto_open": {
      "on_create": false
    },
    "hide_hidden": false,
    "button": true,
    "dock": "right",
    "default_width": 400.0,
    "hide_root": true,
    "auto_fold_dirs": false,
    "starts_open": false,
    "git_status": true,
    "sticky_scroll": false,
    "scrollbar": {
      "show": "never"
    },
    "indent_guides": {
      "show": "never"
    }
  },
  "outline_panel": {
    "default_width": 300,
    "indent_guides": {
      "show": "never"
    }
  },
  "file_finder": {
    "modal_max_width": "large"
  }
}
